# Cloudflare Turnstile (https://dash.cloudflare.com -> Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Resend (https://resend.com -> API Keys)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# Contact email (where form submissions are sent)
CONTACT_EMAIL=your@email.com

# Local dev only – set to true to skip Turnstile verification
NEXT_PUBLIC_TURNSTILE_BYPASS=false
TURNSTILE_BYPASS=false
